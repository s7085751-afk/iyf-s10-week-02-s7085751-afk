<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Partner registration|Home and Away Destinations</title>
    </head>
    <body>
        <form action="/submit-registration"
        method="POST"enctype="multipart/form-data">
        <h1>User Rgistration Form</h1>
        </form> 
        <fieldset>
            <legend>Personal Information</legend>
            <label for="First name">First name:</label>
            <input type="text"id="First name"name="First name"required><br><br>

            <label for="Last name">Last name:</label>
            <input type="text"id="Last name"name="Last name"required><br><br>

            <label for="Dob">Date of Birth:</label>
            <input type="date"id="Date of Birth"name="Date of Birth"required><br><br>

            <label for="age">Age:</label>
            <input type="number"id="age"name="age"required><br><br>

            <span>Gender:</span>
            <input type="radio"id="male"name="Gender"value="male">
            <label for="male">Male</label>
            <input type="radio"id="female"name="Gender"value="female">
            <label for="female">Female</label><br><br>

            <label for="Profile pic">Profile picture:</label>
            <input type="file"id="Profile pic"name="Profile pic"accept="image/*"><br><br>
        </fieldset>
</form>
    </body>

    